{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM"],
    "outDir": "dist/main",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": false,
    "removeComments": false,
    "types": ["node"]
  },
  "include": [
    "src/main/**/*.ts",
    "src/renderer/**/*",
    "src/preload/**/*.ts",
    "src/service/**/*.ts",
    "src/types/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "src/renderer"]
}
